/**
 * Main Statistics Screen
 *
 * Features:
 * - Global stats overview cards
 * - Tab navigation (History/Levels/Achievements)
 * - Child-friendly design with large icons and colors
 */
@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun StatisticsScreen(
    onNavigateBack: () -> Unit,
    viewModel: StatisticsViewModel = viewModel(factory = AppServiceLocator.provideFactory()),
) {
    val uiState by viewModel.uiState.collectAsState()
    val pagerState = rememberPagerState(pageCount = { 3 })
    val coroutineScope = rememberCoroutineScope()

    // Load statistics on first composition
    LaunchedEffect(Unit) {
        viewModel.loadStatistics()
    }

    Scaffold(
        topBar = {
            StatisticsAppBar(onNavigateBack = onNavigateBack)
        },
    ) { paddingValues ->
        when (val state = uiState) {
            is StatisticsUiState.Loading -> {
                Box(
                    modifier = Modifier
                        .fillMaxSize()
                        .padding(paddingValues),
                    contentAlignment = Alignment.Center,
                ) {
                    CircularProgressIndicator(
                        color = MaterialTheme.colorScheme.primary,
                    )
                }
            }

            is StatisticsUiState.Ready -> {
                Column(
                    modifier = Modifier
                        .fillMaxSize()
                        .padding(paddingValues),
                ) {
                    // Global Stats Overview
                    GlobalStatsSection(
                        globalStats = state.globalStats,
                        modifier = Modifier.padding(16.dp),
                    )

                    // Tab Row
                    StatisticsTabRow(
                        selectedTab = pagerState.currentPage,
                        onTabSelected = { index ->
                            coroutineScope.launch {
                                pagerState.animateScrollToPage(index)
                            }
                        },
                    )

                    // Tab Content
                    HorizontalPager(
                        state = pagerState,
                        modifier = Modifier.fillMaxSize(),
                    ) { page ->
                        when (StatisticsTab.entries[page]) {
                            StatisticsTab.HISTORY -> {
                                GameHistoryContent()
                            }
                            StatisticsTab.LEVELS -> {
                                LevelStatisticsContent()
                            }
                            StatisticsTab.ACHIEVEMENTS -> {
                                AchievementContent()
                            }
                        }
                    }
                }
            }

            is StatisticsUiState.Error -> {
                ErrorContent(
                    message = state.message,
                    onNavigateBack = onNavigateBack,
                    modifier = Modifier.padding(paddingValues),
                )
            }
        }
    }
}

/**
 * App bar for statistics screen
 */
@Composable
private fun StatisticsAppBar(onNavigateBack: () -> Unit) {
    TopAppBar(
        title = {
            Text(
                text = "学习统计",
                style = MaterialTheme.typography.titleLarge,
                fontWeight = FontWeight.Bold,
            )
        },
        navigationIcon = {
            IconButton(onClick = onNavigateBack) {
                Icon(
                    imageVector = Icons.Default.ArrowBack,
                    contentDescription = "Back",
                )
            }
        },
        colors = TopAppBarDefaults.topAppBarColors(
            containerColor = MaterialTheme.colorScheme.primaryContainer,
            titleContentColor = MaterialTheme.colorScheme.onPrimaryContainer,
        ),
    )
}

/**
 * Global stats overview section with cards
 */
@Composable
private fun GlobalStatsSection(
    globalStats: com.wordland.ui.uistate.GlobalStatsUiModel,
    modifier: Modifier = Modifier,
) {
    Column(
        modifier = modifier.fillMaxWidth(),
        verticalArrangement = Arrangement.spacedBy(12.dp),
    ) {
        // Section title
        Text(
            text = "我的成就",
            style = MaterialTheme.typography.titleMedium,
            fontWeight = FontWeight.Bold,
            color = MaterialTheme.colorScheme.onSurfaceVariant,
        )

        // Stats cards grid
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.spacedBy(12.dp),
        ) {
            // Total Games Card
            GlobalStatCard(
                icon = "🎮",
                value = globalStats.totalGames.toString(),
                label = "总游戏数",
                color = MaterialTheme.colorScheme.primary,
                modifier = Modifier.weight(1f),
            )

            // Total Score Card
            GlobalStatCard(
                icon = "⭐",
                value = globalStats.totalScore.toString(),
                label = "总得分",
                color = MaterialTheme.colorScheme.tertiary,
                modifier = Modifier.weight(1f),
            )
        }

        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.spacedBy(12.dp),
        ) {
            // Study Time Card
            GlobalStatCard(
                icon = "⏱️",
                value = StudyTimeDisplay.format(globalStats.totalStudyTime),
                label = "学习时长",
                color = MaterialTheme.colorScheme.secondary,
                modifier = Modifier.weight(1f),
            )

            // Streak Card
            GlobalStatCard(
                icon = if (globalStats.currentStreak >= 7) "🔥" else "📅",
                value = "${globalStats.currentStreak}天",
                label = if (globalStats.currentStreak >= 7) "连续学习" else "当前连续",
                color = if (globalStats.currentStreak >= 7) {
                    Color(0xFFFF6B35)
                } else {
                    MaterialTheme.colorScheme.primary
                },
                modifier = Modifier.weight(1f),
                showBadge = globalStats.currentStreak >= 7,
            )
        }

        // Additional stats row
        if (globalStats.totalLevelsCompleted > 0 || globalStats.totalWordsMastered > 0) {
            Surface(
                modifier = Modifier.fillMaxWidth(),
                shape = RoundedCornerShape(16.dp),
                color = MaterialTheme.colorScheme.surfaceVariant,
            ) {
                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(16.dp),
                    horizontalArrangement = Arrangement.SpaceEvenly,
                ) {
                    CompactStatItem(
                        icon = "🏆",
                        value = globalStats.totalLevelsCompleted.toString(),
                        label = "完成关卡",
                    )
                    CompactStatItem(
                        icon = "📚",
                        value = globalStats.totalWordsMastered.toString(),
                        label = "掌握单词",
                    )
                    if (globalStats.longestStreak > 0) {
                        CompactStatItem(
                            icon = "🎯",
                            value = globalStats.longestStreak.toString(),
                            label = "最长连续",
                        )
                    }
                }
            }
        }
    }
}

/**
 * Individual global stat card with gradient background
 */
@Composable
private fun GlobalStatCard(
    icon: String,
    value: String,
    label: String,
    color: Color,
    modifier: Modifier = Modifier,
    showBadge: Boolean = false,
) {
    var cardScale by androidx.compose.runtime.mutableStateOf(1f)
    val scale by androidx.compose.animation.core.animateFloatAsState(
        targetValue = cardScale,
        animationSpec = spring(
            dampingRatio = Spring.DampingRatioMediumBouncy,
            stiffness = Spring.StiffnessLow,
        ),
        label = "card_scale",
    )

    Surface(
        modifier = modifier
            .fillMaxWidth()
            .height(100.dp)
            .animateContentSize(),
        shape = RoundedCornerShape(20.dp),
        color = color.copy(alpha = 0.15f),
        tonalElevation = 4.dp,
        onClick = {
            // Subtle scale animation on click
            cardScale = 0.95f
            androidx.compose.runtime.LaunchedEffect(Unit) {
                kotlinx.coroutines.delay(100)
                cardScale = 1f
            }
        },
    ) {
        Box(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp),
        ) {
            // Badge indicator
            if (showBadge) {
                Box(
                    modifier = Modifier
                        .align(Alignment.TopEnd)
                        .size(24.dp)
                        .clip(CircleShape)
                        .background(color),
                    contentAlignment = Alignment.Center,
                ) {
                    Text(
                        text = "!",
                        color = Color.White,
                        style = MaterialTheme.typography.labelSmall,
                        fontWeight = FontWeight.Bold,
                    )
                }
            }

            Column(
                modifier = Modifier.fillMaxSize(),
                horizontalAlignment = Alignment.CenterHorizontally,
                verticalArrangement = Arrangement.Center,
            ) {
                // Icon
                Text(
                    text = icon,
                    style = MaterialTheme.typography.displayMedium,
                )

                Spacer(modifier = Modifier.height(4.dp))

                // Value
                Text(
                    text = value,
                    style = MaterialTheme.typography.headlineSmall,
                    fontWeight = FontWeight.Bold,
                    color = color,
                )

                // Label
                Text(
                    text = label,
                    style = MaterialTheme.typography.labelSmall,
                    color = MaterialTheme.colorScheme.onSurfaceVariant,
                    textAlign = TextAlign.Center,
                )
            }
        }
    }
}

/**
 * Compact stat item for additional stats row
 */
@Composable
private fun CompactStatItem(
    icon: String,
    value: String,
    label: String,
) {
    Column(
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.spacedBy(4.dp),
    ) {
        Text(
            text = icon,
            style = MaterialTheme.typography.titleLarge,
        )
        Text(
            text = value,
            style = MaterialTheme.typography.titleSmall,
            fontWeight = FontWeight.Bold,
            color = MaterialTheme.colorScheme.primary,
        )
        Text(
            text = label,
            style = MaterialTheme.typography.labelSmall,
            color = MaterialTheme.colorScheme.onSurfaceVariant,
        )
    }
}

/**
 * Custom tab row for statistics
 */
@Composable
private fun StatisticsTabRow(
    selectedTab: Int,
    onTabSelected: (Int) -> Unit,
) {
    Surface(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 16.dp, vertical = 8.dp),
        shape = RoundedCornerShape(16.dp),
        color = MaterialTheme.colorScheme.surfaceVariant,
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(4.dp),
            horizontalArrangement = Arrangement.SpaceEvenly,
        ) {
            StatisticsTab.entries.forEachIndexed { index, tab ->
                TabButton(
                    selected = selectedTab == index,
                    onClick = { onTabSelected(index) },
                    tab = tab,
                    modifier = Modifier.weight(1f),
                )
            }
        }
    }
}

/**
 * Individual tab button
 */
@Composable
private fun TabButton(
    selected: Boolean,
    onClick: () -> Unit,
    tab: StatisticsTab,
    modifier: Modifier = Modifier,
) {
    val backgroundColor = if (selected) {
        MaterialTheme.colorScheme.primary
    } else {
        Color.Transparent
    }
    val contentColor = if (selected) {
        MaterialTheme.colorScheme.onPrimary
    } else {
        MaterialTheme.colorScheme.onSurfaceVariant
    }

    Surface(
        onClick = onClick,
        modifier = modifier
            .fillMaxWidth()
            .height(48.dp),
        shape = RoundedCornerShape(12.dp),
        color = backgroundColor,
    ) {
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.Center,
            verticalAlignment = Alignment.CenterVertically,
        ) {
            val icon = when (tab) {
                StatisticsTab.HISTORY -> Icons.Outlined.History
                StatisticsTab.LEVELS -> Icons.Outlined.BarChart
                StatisticsTab.ACHIEVEMENTS -> Icons.Outlined.Star
            }

            Icon(
                imageVector = icon,
                contentDescription = null,
                tint = contentColor,
                modifier = Modifier.size(20.dp),
            )

            Spacer(modifier = Modifier.width(4.dp))

            Text(
                text = when (tab) {
                    StatisticsTab.HISTORY -> "历史"
                    StatisticsTab.LEVELS -> "关卡"
                    StatisticsTab.ACHIEVEMENTS -> "成就"
                },
                style = MaterialTheme.typography.labelLarge,
                fontWeight = if (selected) FontWeight.Bold else FontWeight.Normal,
                color = contentColor,
            )
        }
    }
}

/**
 * Error content
 */
@Composable
private fun ErrorContent(
    message: String,
    onNavigateBack: () -> Unit,
    modifier: Modifier = Modifier,
) {
    Box(
        modifier = modifier.fillMaxSize(),
        contentAlignment = Alignment.Center,
    ) {
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(16.dp),
        ) {
            Text(
                text = "😅",
                style = MaterialTheme.typography.displayLarge,
            )
            Text(
                text = message,
                style = MaterialTheme.typography.bodyLarge,
                color = MaterialTheme.colorScheme.error,
                textAlign = TextAlign.Center,
            )
        }
    }
}

