import com.wordland.ui.uistate.GameHistoryUiState
import kotlinx.coroutines.delay

/**
 * Game History Screen
 *
 * Shows a list of past games with filtering options
 */
@Composable
fun GameHistoryContent(
    uiState: GameHistoryUiState,
    onLoadMore: () -> Unit = {},
    onGameClick: (String) -> Unit = {},
    onFilterChange: (GameMode?) -> Unit = {},
) {
    val listState = rememberLazyListState()

    // Detect when reaching end of list
    LaunchedEffect(listState) {
        snapshotFlow { listState.layoutInfo.visibleItemsInfo.lastOrNull()?.index }
            .collect { lastVisibleIndex ->
                when (val state = uiState) {
                    is GameHistoryUiState.Ready -> {
                        if (lastVisibleIndex != null && lastVisibleIndex >= state.history.size - 3 && state.hasMore) {
                            onLoadMore()
                        }
                    }
                    else -> {}
                }
            }
    }

    when (val state = uiState) {
        is GameHistoryUiState.Loading -> {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center,
            ) {
                CircularProgressIndicator()
            }
        }

        is GameHistoryUiState.Ready -> {
            if (state.history.isEmpty()) {
                EmptyHistoryState()
            } else {
                Column(
                    modifier = Modifier.fillMaxSize(),
                ) {
                    // Filter bar
                    HistoryFilterBar(
                        selectedFilter = state.filter,
                        onFilterChange = onFilterChange,
                    )

                    // History list
                    LazyColumn(
                        state = listState,
                        modifier = Modifier.fillMaxSize(),
                        contentPadding = PaddingValues(16.dp),
                        verticalArrangement = Arrangement.spacedBy(12.dp),
                    ) {
                        items(
                            items = state.history,
                            key = { it.gameId },
                        ) { game ->
                            GameHistoryCard(
                                game = game,
                                onClick = { onGameClick(game.gameId) },
                            )
                        }

                        // Loading indicator at bottom
                        if (state.hasMore) {
                            item {
                                Box(
                                    modifier = Modifier
                                        .fillMaxWidth()
                                        .padding(16.dp),
                                    contentAlignment = Alignment.Center,
                                ) {
                                    CircularProgressIndicator(
                                        modifier = Modifier.size(24.dp),
                                    )
                                }
                            }
                        }
                    }
                }
            }
        }

        is GameHistoryUiState.Error -> {
            ErrorHistoryState(
                message = state.message,
                onRetry = onLoadMore,
            )
        }
    }
}

/**
 * Filter bar for game history
 */
@Composable
private fun HistoryFilterBar(
    selectedFilter: GameMode?,
    onFilterChange: (GameMode?) -> Unit,
) {
    val filters = listOf(
        null to "全部",
        GameMode.SPELL_BATTLE to "拼写战斗",
        GameMode.QUICK_JUDGE to "快速判断",
    )

    ScrollableTabRow(
        selectedTabIndex = filters.indexOfFirst { it.first == selectedFilter },
        modifier = Modifier.fillMaxWidth(),
        containerColor = MaterialTheme.colorScheme.surface,
        edgePadding = 16.dp,
    ) {
        filters.forEach { (mode, label) ->
            FilterChip(
                selected = selectedFilter == mode,
                onClick = { onFilterChange(mode) },
                label = {
                    Text(
                        text = label,
                        style = MaterialTheme.typography.labelLarge,
                    )
                },
                leadingIcon = if (selectedFilter == mode) {
                    {
                        Icon(
                            imageVector = Icons.Default.ChevronRight,
                            contentDescription = null,
                            modifier = Modifier.size(16.dp),
                        )
                    }
                } else null,
            )
        }
    }
}

/**
 * Individual game history card
 */
@Composable
private fun GameHistoryCard(
    game: GameHistoryItemUiModel,
    onClick: () -> Unit,
) {
    var isPressed by remember { mutableStateOf(false) }
    val scale by animateFloatAsState(
        targetValue = if (isPressed) 0.98f else 1f,
        animationSpec = spring(
            dampingRatio = Spring.DampingRatioMediumBouncy,
            stiffness = Spring.StiffnessMedium,
        ),
        label = "card_scale",
    )

    Card(
        onClick = {
            isPressed = true
            onClick()
            // Reset pressed state after animation
            kotlinx.coroutines.launch {
                delay(100)
                isPressed = false
            }
        },
        modifier = Modifier
            .fillMaxWidth()
            .scale(scale),
        shape = RoundedCornerShape(16.dp),
        colors = CardDefaults.cardColors(
            containerColor = when {
                game.stars == 3 -> MaterialTheme.colorScheme.primaryContainer.copy(alpha = 0.3f)
                game.stars == 2 -> MaterialTheme.colorScheme.secondaryContainer.copy(alpha = 0.2f)
                else -> MaterialTheme.colorScheme.surface
            },
        ),
        elevation = CardDefaults.cardElevation(
            defaultElevation = if (game.stars == 3) 4.dp else 2.dp,
        ),
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            verticalAlignment = Alignment.CenterVertically,
        ) {
            // Game mode icon
            GameModeIcon(
                mode = game.gameMode,
                modifier = Modifier.size(56.dp),
            )

            Spacer(modifier = Modifier.width(16.dp))

            // Game info
            Column(
                modifier = Modifier.weight(1f),
                verticalArrangement = Arrangement.spacedBy(4.dp),
            ) {
                Text(
                    text = game.levelName,
                    style = MaterialTheme.typography.titleMedium,
                    fontWeight = FontWeight.Bold,
                )

                Row(
                    horizontalArrangement = Arrangement.spacedBy(8.dp),
                    verticalAlignment = Alignment.CenterVertically,
                ) {
                    Surface(
                        shape = RoundedCornerShape(8.dp),
                        color = MaterialTheme.colorScheme.surfaceVariant,
                    ) {
                        Text(
                            text = when (game.gameMode) {
                                GameMode.SPELL_BATTLE -> "拼写"
                                GameMode.QUICK_JUDGE -> "判断"
                                GameMode.LISTEN_FIND -> "听力"
                                GameMode.SENTENCE_MATCH -> "配对"
                            },
                            modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp),
                            style = MaterialTheme.typography.labelSmall,
                            color = MaterialTheme.colorScheme.onSurfaceVariant,
                        )
                    }

                    Text(
                        text = "${(game.accuracy * 100).toInt()}% 正确率",
                        style = MaterialTheme.typography.bodySmall,
                        color = getAccuracyColor(game.accuracy),
                    )

                    if (game.maxCombo >= 3) {
                        Text(
                            text = "🔥 ${game.maxCombo}连击",
                            style = MaterialTheme.typography.bodySmall,
                        )
                    }
                }

                Text(
                    text = formatTimestamp(game.timestamp),
                    style = MaterialTheme.typography.labelSmall,
                    color = MaterialTheme.colorScheme.onSurfaceVariant,
                )
            }

            Spacer(modifier = Modifier.width(8.dp))

            // Score and stars
            Column(
                horizontalAlignment = Alignment.End,
            ) {
                Text(
                    text = "${game.score}",
                    style = MaterialTheme.typography.headlineSmall,
                    fontWeight = FontWeight.Bold,
                    color = MaterialTheme.colorScheme.primary,
                )

                // Star rating (compact)
                Row(
                    horizontalArrangement = Arrangement.spacedBy(2.dp),
                ) {
                    repeat(3) { index ->
                        val isFilled = index < game.stars
                        Text(
                            text = if (isFilled) "⭐" else "☆",
                            style = MaterialTheme.typography.labelSmall,
                            color = if (isFilled) {
                                Color(0xFFFFB347)
                            } else {
                                MaterialTheme.colorScheme.surfaceVariant
                            },
                        )
                    }
                }
            }
        }
    }
}

/**
 * Game mode icon with emoji
 */
@Composable
private fun GameModeIcon(
    mode: GameMode,
    modifier: Modifier = Modifier,
) {
    val (emoji, color) = when (mode) {
        GameMode.SPELL_BATTLE -> "⚔️" to MaterialTheme.colorScheme.primary
        GameMode.QUICK_JUDGE -> "⚡" to MaterialTheme.colorScheme.tertiary
        GameMode.LISTEN_FIND -> "🎧" to MaterialTheme.colorScheme.secondary
        GameMode.SENTENCE_MATCH -> "🔗" to MaterialTheme.colorScheme.primary
    }

    Box(
        modifier = modifier
            .clip(CircleShape)
            .background(color.copy(alpha = 0.15f)),
        contentAlignment = Alignment.Center,
    ) {
        Text(
            text = emoji,
            style = MaterialTheme.typography.displaySmall,
        )
    }
}

/**
 * Empty history state
 */
@Composable
private fun EmptyHistoryState() {
    Box(
        modifier = Modifier.fillMaxSize(),
        contentAlignment = Alignment.Center,
    ) {
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(16.dp),
        ) {
            Text(
                text = "📭",
                style = MaterialTheme.typography.displayLarge,
            )

            Text(
                text = "还没有游戏记录",
                style = MaterialTheme.typography.titleMedium,
            )

            Text(
                text = "开始游戏来查看你的历史记录吧！",
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.onSurfaceVariant,
                textAlign = TextAlign.Center,
            )
        }
    }
}

/**
 * Error history state
 */
@Composable
private fun ErrorHistoryState(
    message: String,
    onRetry: () -> Unit,
) {
    Box(
        modifier = Modifier.fillMaxSize(),
        contentAlignment = Alignment.Center,
    ) {
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(16.dp),
        ) {
            Text(
                text = "😓",
                style = MaterialTheme.typography.displayLarge,
            )

            Text(
                text = message,
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.error,
            )

            Button(onClick = onRetry) {
                Text("重试")
            }
        }
    }
}

/**
 * Format timestamp to relative time
 */
private fun formatTimestamp(timestamp: Long): String {
    val now = System.currentTimeMillis()
    val diff = now - timestamp

    return when {
        diff < 60000 -> "刚刚"
        diff < 3600000 -> "${diff / 60000} 分钟前"
        diff < 86400000 -> "${diff / 3600000} 小时前"
        diff < 604800000 -> "${diff / 86400000} 天前"
        else -> {
            val date = java.util.Date(timestamp)
            val format = java.text.SimpleDateFormat("MM月dd日", java.util.Locale.getDefault())
            format.format(date)
        }
    }
}

/**
 * Get color based on accuracy
 */
private fun getAccuracyColor(accuracy: Float): Color {
    return when {
        accuracy >= 0.9f -> Color(0xFF4CAF50) // Green
        accuracy >= 0.7f -> Color(0xFF2196F3) // Blue
        accuracy >= 0.5f -> Color(0xFFFF9800) // Orange
        else -> Color(0xFFF44336) // Red
    }
}
