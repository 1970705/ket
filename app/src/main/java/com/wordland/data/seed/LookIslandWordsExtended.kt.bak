    /**
     * Get all 60 words for Look Island
     */
    fun getAllWords(): List<Word> {
        return allLookWords
    }

    /**
     * Get words for specific level (1-10)
     * Each level has 6 words
     */
    fun getWordsForLevel(levelIndex: Int): List<Word> {
        // levelIndex: 0-9 (for levels 1-10)
        val startIndex = levelIndex * 6
        val endIndex = minOf(startIndex + 6, allLookWords.size)
        return if (startIndex < allLookWords.size) {
            allLookWords.subList(startIndex, endIndex)
        } else {
            emptyList()
        }
    }

    /**
     * Get word by ID
     */
    fun getWordById(wordId: String): Word? {
        return allLookWords.find { it.id == wordId }
    }

    /**
     * Get level ID for a word ID
     * look_001 → look_island_level_01
     */
    fun getLevelIdForWord(wordId: String): String {
        val number = wordId.substring(5).toIntOrNull() ?: 1
        val levelNumber = (number - 1) / 6 + 1
        return "look_island_level_${levelNumber.toString().padStart(2, '0')}"
    }

    /**
     * Get words by difficulty
     */
    fun getWordsByDifficulty(difficulty: Int): List<Word> {
        return allLookWords.filter { it.difficulty == difficulty }
    }

    /**
     * Get KET-only words
     */
    fun getKETWords(): List<Word> {
        return allLookWords.filter { it.ketLevel }
    }

    /**
     * Get PET words (includes KET overlap)
     */
    fun getPETWords(): List<Word> {
        return allLookWords.filter { it.petLevel }
    }
}
